{
  "name": "discord.js-v2",
  "version": "2.0.0",
  "description": "Advanced production-ready Components V2 toolkit for Discord.js v14 — builders, pagination, flows, forms, modals, presets, caching and more.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "types": "./src/index.d.ts"
    },
    "./presets": {
      "require": "./src/presets/index.js"
    },
    "./utils": {
      "require": "./src/utils/index.js"
    }
  },
  "scripts": {
    "test": "node tests/index.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "discord",
    "discord.js",
    "components-v2",
    "discord-components",
    "discord-bot",
    "builder",
    "pagination",
    "forms",
    "wizard",
    "utility"
  ],
  "author": "kopeekool",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faisalgitt/discord.js-v2.git"
  },
  "homepage": "https://github.com/faisalgitt/discord.js-v2#readme",
  "bugs": {
    "url": "https://github.com/faisalgitt/discord.js-v2/issues"
  },
  "peerDependencies": {
    "discord.js": "^14.0.0"
  },
  "devDependencies": {
    "discord.js": "^14.16.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
